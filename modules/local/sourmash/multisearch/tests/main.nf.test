nextflow_process {

    name "Test Process SOURMASH_MULTISEARCH"
    script "../main.nf"
    process "SOURMASH_MULTISEARCH"
    config "./nextflow.config"
    tag "modules"
    tag "modules_local"
    tag "sourmash"
    tag "sourmash/multisearch"

    setup {
        run("SOURMASH_SKETCH") {
            script "modules/nf-core/sourmash/sketch/main.nf"
            process {
                """
                input[0] = [
                    [ id:'test_ecoli' ],
                    file('${projectDir}/assets/sourmash_testing/GCF_000005845.2_ASM584v2_genomic.fna.gz', checkIfExists: true)
                ]
                """
            }
        }
    }

    test("E. coli genome - gtdb_batch_1_k21 database") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = SOURMASH_SKETCH.out.signatures.map{ meta, sig ->
                    [
                        [ id: meta.id, db_name: 'gtdb_batch_1_k21' ],
                        sig,
                        file('${projectDir}/assets/sourmash_testing/db/gtdb_k21_k31_k51_s200_batch_1.zip', checkIfExists: true),
                        21,
                        200
                    ]
                }
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert path(process.out.multisearch_results[0][1]).readLines()[0].contains('query_name,query_md5,match_name') },
                { assert path(process.out.multisearch_results[0][1]).readLines().size() > 1 },
                { assert snapshot(process.out.versions).match() }
            )
        }
    }

    test("E. coli genome - gtdb_batch_2_k31 database") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = SOURMASH_SKETCH.out.signatures.map{ meta, sig ->
                    [
                        [ id: meta.id, db_name: 'gtdb_batch_2_k31' ],
                        sig,
                        file('${projectDir}/assets/sourmash_testing/db/gtdb_k21_k31_k51_s200_batch_2.zip', checkIfExists: true),
                        31,
                        200
                    ]
                }
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert path(process.out.multisearch_results[0][1]).exists() },
                { assert snapshot(process.out.versions).match() }
            )
        }
    }

    test("E. coli genome - gtdb_batch_1_k21 database - stub") {

        options '-stub'

        when {
            process {
                """
                input[0] = [
                    [ id:'test_ecoli', db_name:'gtdb_batch_1_k21' ],
                    file('test.sig.zip'),
                    file('${projectDir}/assets/sourmash_testing/db/gtdb_k21_k31_k51_s200_batch_1.zip', checkIfExists: true),
                    21,
                    200
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

}
