/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running tests for RUN_SOURMASH subworkflow
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

// Base directory for test data
// Using projectDir for test data and downloaded databases
params {
    test_data_base = "${projectDir}/assets/sourmash_testing"
    rankedlineage  = "${projectDir}/NCBI_TAXONOMY/rankedlineage.dmp"
    outdir         = "results"
}

process {
    // Disable publishDir for test runs to avoid cluttering
    publishDir = [
        enabled: false
    ]

    // Configure resource requirements for test runs
    withName: 'SOURMASH_.*' {
        cpus   = 1
        memory = 2.GB
    }

    withName: 'GET_TARGET_TAXA' {
        cpus   = 1
        memory = 1.GB
    }

    withName: 'PARSE_SOURMASH' {
        cpus   = 1
        memory = 1.GB
    }
}
